<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>Knit</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleIdentifier</key>
    <string>co.boldright.knit</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Knit</string>
    <key>CFBundleDisplayName</key>
    <string>Knit</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!--
        Knit.app is intentionally NOT marked as LSUIElement (PR #58 fix).
        macOS does not show the published-NSProgress floating widget or
        the Finder file-icon overlay for background utilities — they
        require a regular foreground app for the system to attach UI to.
        Compare Finder / Safari / Mail / Archive Utility, none of which
        are LSUIElement.

        Trade-off: a Dock icon appears briefly while Knit.app is running
        an operation, then disappears when the operation finishes and
        the app exits. For sub-second operations the icon may flicker
        in and out; for multi-second ones it's visible the whole time
        — which matches what users see for Finder's built-in Compress
        and Archive Utility.
    -->


    <!-- Declare .knit as a new UTI owned by Knit. -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>co.boldright.knit.archive</string>
            <key>UTTypeDescription</key>
            <string>Knit Archive</string>
            <key>UTTypeIconFile</key>
            <string>KnitDocument.icns</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.data</string>
                <string>public.archive</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>knit</string>
                </array>
                <key>public.mime-type</key>
                <array>
                    <string>application/x-knit</string>
                </array>
            </dict>
        </dict>
    </array>

    <!-- Tell Launch Services that Knit can open .knit (and .zip) files. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Knit Archive</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>CFBundleTypeIconFile</key>
            <string>KnitDocument.icns</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>co.boldright.knit.archive</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>
            <string>ZIP Archive</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.zip-archive</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
